# Environment
ENVIRONMENT=dev

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# LLM Providers Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=2048

OPENAI_API_KEY=
GROQ_API_KEY=

# Vector Database (chroma, qdrant, or pinecone)
VECTOR_DB=chroma

# Pinecone Configuration (Optional)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aegis-rag

# Chroma Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Qdrant Configuration (Optional)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_documents

# Embedding Configuration
EMBEDDING_MODEL=models/embedding-001
EMBEDDING_DIMENSION=768
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Cache Configuration
EMBEDDING_CACHE_TYPE=sqlite
EMBEDDING_CACHE_SQLITE_PATH=./cache/embeddings.db
RESPONSE_CACHE_TYPE=redis

# Redis Configuration (Optional, e.g. Upstash)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL=3600

# PostgreSQL Configuration (Optional)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_cache
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Retrieval Settings
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.7

# Tool Registry (Optional)
TAVILY_API_KEY=
ENABLE_WEB_SEARCH=false

# LlamaIndex Configuration (Optional)
LLAMAINDEX_RESPONSE_MODE=compact
LLAMAINDEX_USE_ROUTER=false
LLAMAINDEX_USE_SUBQUESTION=false
LLAMAINDEX_ENABLE_HYBRID=true

# Advanced RAG Options
ENABLE_PARENT_DOCUMENT_RETRIEVAL=false
ENABLE_RERANKING=false
RERANKER_MODEL=gemini
ENABLE_HYBRID_SEARCH=false
PRESIDIO_ENABLED=false
EVAL_ENABLED=false

# Neo4j Settings (Optional)
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
